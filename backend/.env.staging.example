# ── Staging Environment ───────────────────────────────────────────────────────
# Copy to .env on the staging server at /opt/neurobot-staging/backend/.env

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=staging
SECRET_KEY=change-me-to-random-64-char-string
DEBUG=true
ALLOWED_ORIGINS=["https://test.uppetitgpt.ru"]

# ── Database (separate from production!) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://neurobot_user:password@localhost/neurobot_staging_db

# ── Redis (different DB index from production) ───────────────────────────────
REDIS_URL=redis://localhost:6379/2

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
MAX_TOKENS=2000

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=10
MIN_SCORE=0.20
STORAGE_DIR=storage
IMAGES_DIR=kb_images

# ── Google Drive ──────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=uppetitgpt-8eb57cf91dce.json
GDRIVE_FOLDER_ID=1IFsoR553qjscPhQAYzFCA2xb-EOL0N2E
KB_DOWNLOADS_DIR=kb_downloads

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_INITIAL_PASSWORD=
